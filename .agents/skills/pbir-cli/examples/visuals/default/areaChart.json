{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "areaChart_default_example",
  "position": {
    "x": 24,
    "y": 120,
    "z": 0,
    "height": 400,
    "width": 600,
    "tabOrder": 0
  },
  "visual": {
    "visualType": "areaChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Date"
                    }
                  },
                  "Property": "Month"
                }
              },
              "queryRef": "Date.Month",
              "nativeQueryRef": "Month",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Sales"
                    }
                  },
                  "Property": "Revenue"
                }
              },
              "queryRef": "Sales.Revenue",
              "nativeQueryRef": "Revenue"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}
