{
    "_comment": "Packaging exclude rules. dirs/files match exact name (per path segment, including nested). exts match file extension (with dot). patterns are fnmatch globs (applied to both filename and full relative path). Note: 'dirs' only matches directory names, not files of the same name. 'tests' dir is excluded; files prefixed with test_ under scripts/ are NOT auto-excluded (add them to patterns if needed).",
    "dirs": [
        ".git",
        ".svn",
        ".hg",
        "__pycache__",
        ".pytest_cache",
        ".mypy_cache",
        ".ruff_cache",
        ".tox",
        ".hypothesis",
        "htmlcov",
        "dist",
        "build",
        "node_modules",
        ".cache",
        ".next",
        ".nuxt",
        ".vite",
        ".turbo",
        ".idea",
        ".vscode",
        ".clawhub",
        ".secrets",
        ".token",
        "archived",
        "tests",
        ".tmp",
        "tmp",
        "output",
        "logs"
    ],
    "files": [
        ".DS_Store",
        "._.DS_Store",
        "Thumbs.db",
        ".coverage",
        "coverage.xml",
        ".env",
        ".env.local",
        "sign.key",
        ".sign-key",
        "__skill_meta__.json"
    ],
    "exts": [
        ".pyc",
        ".pyo",
        ".bak",
        ".log",
        ".pem",
        ".p12"
    ],
    "patterns": [
        "cloned_*.html",
        "AUDIT-*.md",
        "TEST-*.md",
        "*.json.md",
        "*.yaml.md",
        "*.yml.md",
        "__skill_meta__.*",
        ".tmp_backup_*",
        "*_backup_*",
        "*.pem",
        "id_rsa*",
        "*.private.key"
    ]
}