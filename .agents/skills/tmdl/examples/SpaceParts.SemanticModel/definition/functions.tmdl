	annotation DAXLIB_PackageId = DaxLib.FormatString

	annotation DAXLIB_PackageVersion = 1.0.0-beta

function 'FormatString.Component.GetCurrencyFormat' = ```
		
		// Get currency format based on currency code
		// Returns simple currency format string (i.e. $#,##0.0)
		(
		    // Currency code (ISO 4217 three-letter code)
		    // Examples: CAD, EUR, GBP, JPY, etc.
		    currency_code: ANYREF
		)
		=>
		    VAR _Code = 
		        SELECTEDVALUE ( currency_code )
		    
		    VAR _Currency = 
		        FILTER (
		            -- Calc. table with common currencies and formats
		            -- Optionally replace with your own, in-memory exchange rate table
		            FormatString.Component.CurrencyTable(),
		            ''[Currency Code] = _Code
		        )
		        
		    VAR _Symbol =
		        SELECTCOLUMNS ( _Currency, ''[Format String] )
		    
		    RETURN
		        _Symbol
		```
	lineageTag: 729b49b1-c381-4839-825b-64ec638c7a9c

	annotation DAXLIB_PackageId = DaxLib.FormatString

	annotation DAXLIB_PackageVersion = 1.0.0-beta

function 'FormatString.Component.GetCurrencyFormat.PNZ' = ```
		
		// Get currency format based on currency code
		// Returns positive; negative; zero format string (i.e. $#,##0.0; ($-#,##0.0); $0)
		(
		    // Currency code (ISO 4217 three-letter code)
		    // Examples: CAD, EUR, GBP, JPY, etc.
		    currency_code: ANYREF
		)
		=>
		    VAR _Code = 
		        SELECTEDVALUE ( currency_code )
		    
		    VAR _Currency = 
		        FILTER (
		            -- Calc. table with common currencies and formats
		            -- Optionally replace with your own, in-memory exchange rate table
		            FormatString.Component.CurrencyTable(),
		            ''[Currency Code] = _Code
		        )
		        
		    VAR _Symbol =
		        SELECTCOLUMNS ( _Currency, ''[Format String PNZ] )
		    
		    RETURN
		        _Symbol
		```
	lineageTag: 3d5d7c0c-c33d-4c3d-8afe-7dac63aedab7

	annotation DAXLIB_PackageId = DaxLib.FormatString

	annotation DAXLIB_PackageVersion = 1.0.0-beta

function 'BusCalcs.Pareto' = ```
		
		// Computes the Pareto of a measure by one or more categories
		// Returns the cumulative percentage for that category
		(
		    // Measure or expression that you want to calculate the Pareto for
		    measure_reference: EXPR,
		    
		    // Table expression
		    data_scope: ANYREF
		)
		=>
		    VAR _TotalValue = 
		        measure_reference
		    
		    VAR _MeasureByDataScope =
		        ADDCOLUMNS (
		            ALLSELECTED ( data_scope ),
		            "@Value", measure_reference
		        )
		    
		    VAR _Cumulation =
		        FILTER (
		            _MeasureByDataScope,
		            [@Value] >= _TotalValue
		        )
		    
		    VAR _CumulativeAmount =
		        SUMX ( _Cumulation, [@Value] )
		    
		    VAR _Total =
		        SUMX ( _MeasureByDataScope, [@Value] )
		    
		    VAR _CumulativePercentage =
		        DIVIDE (
		            _CumulativeAmount,
		            _Total,
		            BLANK ( )
		        )
		        
		    RETURN
		        _CumulativePercentage
		```
	lineageTag: a9a359e2-90a6-464c-942d-a86671ad811f

function 'BusCalcs.MovingAverage' = ```
		
		// Calculate moving average over N periods
		(
		    // Measure to average
		    measure_reference: EXPR,
		    
		    // Number of periods
		    periods: INT64,
		    
		    // Column for periods (e.g., Date column)
		    period_column: ANYREF,
		    
		    // Table for periods (e.g., Date table)
		    period_table: ANYREF
		) =>
		    -- Uses approach from Definitive Guide to DAX 2e P202
		    VAR _LastVisibleDate = MAX ( period_column )
		    
		    VAR _NumberOfPeriods = periods
		    
		    VAR _PeriodToUse =
		        FILTER (
		            ALL ( period_table ),
		            period_column > _LastVisibleDate - _NumberOfPeriods &&
		            period_column <= _LastVisibleDate
		        )
		    
		    VAR _Result =
		        CALCULATE (
		            DIVIDE (
		                measure_reference, COUNTROWS ( VALUES ( period_column ) )
		            ),
		            _PeriodToUse
		        )
		    
		    RETURN
		        _Result
		```
	lineageTag: 8b03e8a4-9b65-4612-b304-a65dd9ae0e65

function 'BusCalcs.PercentOfTotal' = ```
		
		// Calculate percent of total within scope
		(
		    // Measure to calculate percentage for
		    measure_reference: EXPR,
		    
		    // Scope to remove for total calculation
		    remove_scope: ANYREF
		) =>
		    DIVIDE (
		        measure_reference,
		        CALCULATE (
		            measure_reference,
		            REMOVEFILTERS ( remove_scope )
		        ),
		        BLANK()
		    )
		```
	lineageTag: 49383946-6b2e-47ff-9b92-7bd30089ab7e

function 'BusCalcs.YearOverYear' = ```
		
		// Calculate year-over-year change
		(
		    // Measure to compare
		    measure_reference: EXPR,
		    
		    // Date column
		    date_column: COLUMNREF,
		    
		    // Return type: "VALUE", "PERCENT", "DELTA"
		    return_type: STRING
		) =>
		    VAR _Current = measure_reference
		    VAR _PriorYear = 
		        CALCULATE (
		            measure_reference,
		            SAMEPERIODLASTYEAR ( date_column )
		        )
		    RETURN
		        SWITCH (
		            return_type,
		            "VALUE", _PriorYear,
		            "DELTA", _Current - _PriorYear,
		            "PERCENT", DIVIDE ( _Current - _PriorYear, _PriorYear, BLANK() ),
		            BLANK()
		        )
		```
	lineageTag: 34df0bb2-4ccc-43eb-881a-82392f1fa1aa

function 'BusCalcs.WeightedAverage' = ```
		
		// Calculate weighted average
		(
		    // Value to average
		    value_column: COLUMNREF,
		    
		    // Weight column
		    weight_column: COLUMNREF,
		    
		    // Table containing both columns
		    data_table: TABLEREF
		) =>
		    DIVIDE (
		        SUMX ( data_table, value_column * weight_column ),
		        SUMX ( data_table, weight_column ),
		        BLANK()
		    )
		```
	lineageTag: e877a57d-d177-4ed1-925e-a00ae39bf4cd

function 'BusCalcs.ABC' = ```
		
		// Classify items into A/B/C categories based on cumulative contribution
		(
		    // Pareto percentage
		    // Use BusCalcs.ABC
		    pareto_pct: SCALAR VAL,
		    
		    // Threshold for A items (e.g., 0.8 for 80%)
		    a_threshold: SCALAR VAL,
		    
		    // Threshold for B items (e.g., 0.95 for 95%)
		    b_threshold: SCALAR VAL
		) =>
		    SWITCH (
		        TRUE(),
		        pareto_pct <= a_threshold, "A",
		        pareto_pct <= b_threshold, "B",
		        "C"
		    )
		```
	lineageTag: 3dec8cb5-e5d2-430a-8357-c95800e3eafc

function 'BusCalcs.RunningTotal' = ```
		
		// Calculate running total over a sorted dimension
		(
		    // Measure to accumulate
		    measure_reference: EXPR,
		    
		    // Column to sort by (typically date)
		    sort_column: COLUMNREF,
		    
		    // Scope for the calculation
		    data_scope: ANYREF
		) =>
		    VAR _CurrentValue = MAX ( sort_column )
		    RETURN
		        CALCULATE (
		            measure_reference,
		            FILTER (
		                ALLSELECTED ( data_scope ),
		                sort_column <= _CurrentValue
		            )
		        )
		```
	lineageTag: 9469fc4a-c3fa-4932-a6d8-59aff4f07037

function 'BusCalcs.MovingSum' = ```
		
		// Calculate moving sum over N periods
		(
		    // Measure to sum
		    measure_reference: EXPR,
		    
		    // Number of periods
		    periods: INT64,
		    
		    // Column for periods (e.g., Date column)
		    period_column: ANYREF,
		    
		    // Table for periods (e.g., Date table)
		    period_table: ANYREF
		) =>
		    VAR _LastVisibleDate = MAX ( period_column )
		    
		    VAR _NumberOfPeriods = periods
		    
		    VAR _PeriodToUse =
		        FILTER (
		            ALL ( period_table ),
		            period_column > _LastVisibleDate - _NumberOfPeriods &&
		            period_column <= _LastVisibleDate
		        )
		    
		    VAR _Result =
		        CALCULATE (
		            measure_reference,
		            _PeriodToUse
		        )
		    
		    RETURN
		        _Result
		```
	lineageTag: 7f7b7492-fcc7-4b49-8841-590dd30ecfc3

