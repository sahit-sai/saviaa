function 'FormatString.Component.MakeStringSafe' =
		
		// Wraps strings in double-quotes to avoid issues with format string interpretation
		(
		    // The value you want to put in the format string
		    unsafe_string : STRING
		)
		=>
		    """" & unsafe_string & """"
