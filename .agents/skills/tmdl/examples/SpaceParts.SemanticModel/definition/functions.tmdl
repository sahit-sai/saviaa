function 'Report.ShowOnlyLatestDataPoint' = ```
		
		// Function to only show the latest data point in a chart
		// - Returns BLANK() for all earlier or later periods.
		(
		    // Granularity for which you only want to see
		    // the latest value. Typically a column reference.
		    // - Example: 'Date'[Workdays MTD] or 'Date'[Date]
		    period: ANYREF,
		    
		    // The scope for which the period is defined.
		    // Typically a column reference.
		    // - Example: 'Date'[Month] or 'Date'[Year]
		    periodScope: ANYREF,
		    
		    // The value for which you want to see the latest data point
		    // Typically a measure reference.
		    // - Example: [Sales MTD] or [Budget]
		    measureValue: ANYREF
		) 
		=>
		    VAR _LatestPeriod =
		        CALCULATE (
		            MAX ( period ),
		            'Date'[IsDateInScope],
		            ALLEXCEPT ( 'Date', periodScope )
		        )
		    RETURN
		        IF (
		            MAX ( period ) = _LatestPeriod,
		            measureValue
		        )
		```
	lineageTag: 46a13890-16f9-488f-9cfa-fb7246ff9fd4

