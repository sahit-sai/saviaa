		) =>
		    "<ellipse cx='" & cx & 
		    "' cy='" & cy & 
		    "' rx='" & rx & 
		    "' ry='" & ry & 
		    "' fill='" & fill_colour & 
		    "' stroke='" & stroke_colour &
		    "' stroke-width='" & stroke_width &
		    "' opacity='" & opacity &
		    "'/>"
