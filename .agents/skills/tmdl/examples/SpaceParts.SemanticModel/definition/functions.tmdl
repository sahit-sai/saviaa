function 'SVG.Component.Polylines' = ```
		
		// SVG.Component.Polyline
		// Creates a polyline (connected points) with optional fill and clipping
		(
		    // Space-separated x,y coordinate pairs
		    // Example: "0,10 20,30 40,15"
		    points : SCALAR VAL,
		    
		    // Fill color or "none" for no fill
		    fill_colour : SCALAR VAL,
		    
		    // Fill opacity (0-1)
		    fill_opacity : SCALAR VAL,
		    
		    // Stroke color
		    stroke_colour : SCALAR VAL,
		    
		    // Stroke width in pixels
		    stroke_width : SCALAR VAL,
		    
		    // Line cap style ("butt", "round", "square")
		    stroke_linecap : SCALAR VAL,
		    
		    // Line join style ("miter", "round", "bevel")
		    stroke_linejoin : SCALAR VAL,
		    
		    // Reference to clip path ID (e.g., "#element")
		    // Enter "" if no clipping needed
		    clip_path_ref : SCALAR VAL,
		    
		    // Optional element ID for this polyline
		    // Enter "" if not needed
		    element_id : SCALAR VAL
		) =>
		    "<polyline" &
		    IF(element_id <> "", " id='" & element_id & "'", "") &
		    " points='" & points & 
		    "' fill='" & fill_colour & 
		    "' fill-opacity='" & fill_opacity &
		    "' stroke='" & stroke_colour & 
		    "' stroke-width='" & stroke_width &
		    "' stroke-linecap='" & stroke_linecap &
		    "' stroke-linejoin='" & stroke_linejoin &
		    IF(clip_path_ref <> "", "' clip-path='url(" & clip_path_ref & ")'", "'") &
		    "/>"
		```
	lineageTag: 74db8a33-96e5-4bf0-bda3-fda27c364399

function 'SVG.Chart.BarChart.OverlappingBars' = ```
		
		// Chart.BarChart.OverlappingBars
		// Creates overlapping bars showing actual vs target with variance indicator
		// Returns SVG string for Table/Matrix visuals
		(
		    // Actual value measure
		    // Example: [Actuals MTD]
		    actual : EXPR,
		    
		    // Target value measure
		    // Example: [Budget MTD]
		    target : EXPR,
		    
		    // Column for grouping/scope
		    // Example: 'Customers'[Key Account Name]
		    group_column : ANYREF,
		    
		    // Color for actual bar
		    // Example: "#686868" (charcoal)
		    colour_actual : SCALAR VAL,
		    
		    // Color for target bar
		    // Example: "#e1dfdd" (grey)
		    colour_target : SCALAR VAL,
		    
		    // Color for negative variance
		    // Example: "#fab005" (yellow)
		    colour_variance_negative : SCALAR VAL,
		    
		    // Color for positive variance
		    // Example: "#2094ff" (blue)
		    color_variance_positive : SCALAR VAL,
		    
		    // Font family for labels
		    // Example: "Segoe UI"
		    text_font_family : SCALAR VAL,
		    
		    // Font size for percentage label
		    // Example: 10
		    text_font_size : SCALAR VAL,
		    
		    // Font weight for labels
		    // Example: 600
		    text_font_weight : SCALAR VAL
		) =>
		    -- Chart dimensions
		    VAR _BarMax = 100
		    VAR _BarMin = 30
		    
		    -- Get current values
		    VAR _Actual = actual
		    VAR _Target = target
		    
		    -- Calculate performance
		    VAR _Performance = DIVIDE(_Actual - _Target, _Target)
		    
		    -- Determine variance color
		    VAR _VarianceColor = 
		        IF(_Performance < 0, colour_variance_negative, color_variance_positive)
		    
		    -- Get scope for axis calculation
		    VAR _Scope = ALLSELECTED(group_column)
		    
		    -- Calculate axis maximums
		    VAR _MaxActualsInScope = 
		        CALCULATE(
		            MAXX(_Scope, actual),
		            REMOVEFILTERS(group_column)
		        )
		    
		    VAR _MaxTargetInScope = 
		        CALCULATE(
		            MAXX(_Scope, target),
		            REMOVEFILTERS(group_column)
		        )
		    
		    VAR _AxisMax = 
		        IF(
		            HASONEVALUE(group_column),
		            MAX(_MaxActualsInScope, _MaxTargetInScope),
		            CALCULATE(MAX(actual, target), REMOVEFILTERS(group_column))
		        ) * 1.1
		    
		    -- Calculate normalized positions
		    VAR _AxisRange = _BarMax - _BarMin
		    
		    VAR _ActualNormalized = 
		        DIVIDE(_Actual, _AxisMax) * _AxisRange
		    
		    VAR _TargetNormalized = 
		        DIVIDE(_Target, _AxisMax) * _AxisRange
		    
		    -- Calculate variance bar position and width
		    VAR _VarianceX = _BarMin + MIN(_ActualNormalized, _TargetNormalized) + 1
		    VAR _VarianceY = IF(_Target > _Actual, 2.9, 9)
		    VAR _VarianceWidth = ABS(_ActualNormalized - _TargetNormalized) - 1
		    
		    -- Build SVG components
		    VAR _SvgContent = 
		        
		        -- Performance Icon (triangle up/down)
		        SVG.Component.Texts(
		            _BarMin - 3,                                    -- x
		            13.5,                                            -- y
		            FORMAT(_Performance, "▲;▼;"),                   -- text_content
		            6,                                               -- text_font_size
		            "Segoe UI",                                      -- font_family
		            _VarianceColor,                                  -- fill
		            "end",                                           -- text_anchor
		            700,                                             -- font_weight
		            "",                                              -- rotation
		            ""                                               -- opacity
		        ) &
		        
		        -- Performance Label (percentage)
		        SVG.Component.Texts(
		            _BarMin - 10,                                    -- x
		            15,                                              -- y
		            FORMAT(_Performance, "#,##0%;#,##0%;#,##0%"),   -- text_content
		            text_font_size,                                       -- text_font_size
		            text_font_family,                                     -- font_family
		            _VarianceColor,                                  -- fill
		            "end",                                           -- text_anchor
		            text_font_weight,                                     -- font_weight
		            "",                                              -- rotation
		            ""                                               -- opacity
		        ) &
		        
		        -- Target Bar (bottom)
		        SVG.Component.Rects(
		            _BarMin,                -- x
		            10,                     -- y
		            _TargetNormalized,      -- width
		            12,                     -- height
		            colour_target,           -- fill
		            colour_actual,           -- stroke (uses actual color for outline)
		            "",                     -- stroke_width
		            "",                     -- rx
		            ""                      -- opacity
		        ) &
		        
		        -- Actual Bar (top)
		        SVG.Component.Rects(
		            _BarMin,                -- x
		            3,                      -- y
		            _ActualNormalized,      -- width
		            12,                     -- height
		            colour_actual,           -- fill
		            colour_actual,           -- stroke
		            "",                     -- stroke_width
		            "",                     -- rx
		            ""                      -- opacity
		        ) &
		        
		        -- Variance Bar
		        SVG.Component.Rects(
		            _VarianceX,             -- x
		            _VarianceY,             -- y
		            _VarianceWidth,         -- width
		            6,                      -- height
		            _VarianceColor,         -- fill
		            _VarianceColor,         -- stroke
		            "",                     -- stroke_width
		            "",                     -- rx
		            ""                      -- opacity
		        )
		    
		    -- Wrap in PowerBI container with sort value
		    VAR _Svg = 
		        SVG.Component.PowerBI(
		            _SvgContent,
		            _Actual,                -- sort_value
		            "",                     -- viewbox (uses default)
		            "",                     -- width (uses default)
		            "",                     -- height (uses default)
		            "#FFFFFF00"             -- transparent background
		        )
		    
		    RETURN
		        _Svg
		```
	lineageTag: 922a5d51-8b34-4590-9066-539dbd786178

function 'SVG.Chart.BarChart.OverlappingBarsSimple' = ```
		
		// Chart.BarChart.OverlappingBarsSimple
		// Creates overlapping bars showing actual vs target with variance bar (no text labels)
		// Returns SVG string for Table/Matrix visuals
		(
		    // Actual value measure
		    // Example: [Actuals MTD]
		    actual : EXPR,
		    
		    // Target value measure
		    // Example: [Budget MTD]
		    target : EXPR,
		    
		    // Column for grouping/scope
		    // Example: 'Customers'[Key Account Name]
		    column_one : ANYREF,
		    
		    // Colour for actual bar
		    // Example: "#686868" (charcoal)
		    colour_actual : SCALAR VAL,
		    
		    // Colour for target bar
		    // Example: "#e1dfdd" (grey)
		    colour_target : SCALAR VAL,
		    
		    // Colour for negative variance
		    // Example: "#fab005" (yellow)
		    colour_variance_negative : SCALAR VAL,
		    
		    // Colour for positive variance
		    // Example: "#2094ff" (blue)
		    colour_variance_positive : SCALAR VAL
		) =>
		    -- Chart dimensions
		    VAR _BarMax = 100
		    VAR _BarMin = 10  -- Can start closer to edge without labels
		    
		    -- Get current values
		    VAR _Actual = actual
		    VAR _Target = target
		    
		    -- Calculate performance
		    VAR _Performance = DIVIDE(_Actual - _Target, _Target)
		    
		    -- Determine variance Colour
		    VAR _VarianceColour = 
		        IF(_Performance < 0, colour_variance_negative, colour_variance_positive)
		    
		    VAR _AxisMax = 
		        MAX (
		            SVG.Calc.AxisMax( actual, column_one, 1.1 ),
		            SVG.Calc.AxisMax( target, column_one, 1.1 )
		        )
		    
		    -- Calculate normalized positions
		    VAR _AxisRange =
		        SVG.Calc.AxisRange ( _BarMax, _BarMin )
		    
		    VAR _ActualNormalized = 
		        SVG.Calc.Normalize ( actual, _AxisMax, _AxisRange )
		    
		    VAR _TargetNormalized = 
		        SVG.Calc.Normalize ( target, _AxisMax, _AxisRange )
		    
		    -- Calculate variance bar position and width
		    VAR _VarianceX = _BarMin + MIN(_ActualNormalized, _TargetNormalized) + 1
		    VAR _VarianceY = IF(_Target > _Actual, 2.9, 9)
		    VAR _VarianceWidth = ABS(_ActualNormalized - _TargetNormalized) - 1
		    
		    -- Build SVG components (no text labels)
		    VAR _SvgContent = 
		        
		        -- Target Bar (bottom)
		        SVG.Component.Rects(
		            _BarMin,                -- x
		            10,                     -- y
		            _TargetNormalized,      -- width
		            12,                     -- height
		            colour_target,           -- fill
		            colour_actual,           -- stroke (uses actual Colour for outline)
		            "",                     -- stroke_width
		            "",                     -- rx
		            ""                      -- opacity
		        ) &
		        
		        -- Actual Bar (top)
		        SVG.Component.Rects(
		            _BarMin,                -- x
		            3,                      -- y
		            _ActualNormalized,      -- width
		            12,                     -- height
		            colour_actual,           -- fill
		            colour_actual,           -- stroke
		            "",                     -- stroke_width
		            "",                     -- rx
		            ""                      -- opacity
		        ) &
		        
		        -- Variance Bar
		        SVG.Component.Rects(
		            _VarianceX,             -- x
		            _VarianceY,             -- y
		            _VarianceWidth,         -- width
		            6,                      -- height
		            _VarianceColour,         -- fill
		            _VarianceColour,         -- stroke
		            "",                     -- stroke_width
		            "",                     -- rx
		            ""                      -- opacity
		        )
		    
		    -- Wrap in PowerBI container with sort value
		    VAR _Svg = 
		        SVG.Component.PowerBI(
		            _SvgContent,
		            _Actual,                -- sort_value
		            "",                     -- viewbox (uses default)
		            "",                     -- width (uses default)
		            "",                     -- height (uses default)
		            "#FFFFFF00"             -- transparent background
		        )
		    
		    RETURN
		        _Svg
		```
	lineageTag: 7a4e7d3c-39f7-4a1a-a433-89912e00320e

function 'SVG.Chart.DumbbellPlot' = ```
		
		// Chart.DumbbellPlot
		// Creates a dumbbell chart showing actual vs target with connecting line
		// Returns SVG string for Table/Matrix visuals (set Image size: Height 25px, Width 100px)
		(
		    // Actual value measure
		    // Example: [Sales Amount]
		    actual : EXPR,
		    
		    // Target value measure
		    // Example: [Sales Target]
		    target : EXPR,
		    
		    // Column for grouping/scope
		    // Example: 'Product'[Category]
		    column_one : ANYREF,
		    
		    // Colour when actual exceeds target
		    // Example: "#448FD6" (blue)
		    colour_on_target_fill : SCALAR VAL,
		    
		    // Stroke colour when actual exceeds target
		    // Example: "#2F6698" (dark blue)
		    colour_on_target_stroke : SCALAR VAL,
		    
		    // Colour when actual below target
		    // Example: "#D64444" (red)
		    colour_off_target_fill : SCALAR VAL,
		    
		    // Stroke colour when actual below target
		    // Example: "#982F2F" (dark red)
		    colour_off_target_stroke : SCALAR VAL
		) =>
		    -- SVG dimensions
		    VAR _SvgWidth = 100
		    VAR _SvgMin = 0
		    VAR _SvgHeight = 25
		    VAR _CenterY = _SvgHeight / 2
		    
		    -- Fixed colours
		    VAR _TargetCircleColour = "#F5F5F5"
		    VAR _TargetStrokeColour = "#C7C7C7"
		    VAR _AxisColour = "#C7C7C7"
		    
		    -- Get current values
		    VAR _Actual = actual
		    VAR _Target = target
		    
		    -- Determine colours based on performance
		    VAR _Fill = IF(_Actual > _Target, colour_on_target_fill, colour_off_target_fill)
		    VAR _Stroke = IF(_Actual > _Target, colour_on_target_stroke, colour_off_target_stroke)
		    
		    -- Use existing calculation functions
		    VAR _AxisMax = 
		        MAX(
		            SVG.Calc.AxisMax(actual, column_one, 1.1),
		            SVG.Calc.AxisMax(target, column_one, 1.1)
		        )
		    
		    -- Calculate normalized positions using existing functions
		    VAR _AxisRange = 
		        SVG.Calc.AxisRange(_SvgWidth, _SvgMin)
		    
		    VAR _ActualNormalized = 
		        SVG.Calc.Normalize(_Actual, _AxisMax, _AxisRange)
		    
		    VAR _TargetNormalized = 
		        SVG.Calc.Normalize(_Target, _AxisMax, _AxisRange)
		    
		    -- Build SVG components
		    VAR _SvgContent = 
		        
		        -- Axis line
		        SVG.Component.Lines(
		            0,                      -- x1
		            _CenterY,               -- y1
		            _SvgWidth,              -- x2
		            _CenterY,               -- y2
		            _AxisColour,            -- stroke_colour
		            1,                      -- stroke_width
		            "",                     -- stroke_dasharray
		            "",                     -- stroke_linecap
		            ""                      -- opacity
		        ) &
		        
		        -- Origin circle
		        SVG.Component.Circles(
		            2,                      -- cx
		            _CenterY,               -- cy
		            2,                      -- radius
		            _AxisColour             -- fill
		        ) &
		        
		        -- Dumbbell connecting line
		        SVG.Component.Lines(
		            _ActualNormalized,      -- x1
		            _CenterY,               -- y1
		            _TargetNormalized,      -- x2
		            _CenterY,               -- y2
		            _Fill,                  -- stroke_colour (uses actual colour)
		            3,                      -- stroke_width
		            "",                     -- stroke_dasharray
		            "",                     -- stroke_linecap
		            ""                      -- opacity
		        ) &
		        
		        -- Target circle with stroke
		        "<circle cx='" & _TargetNormalized & 
		        "' cy='" & _CenterY & 
		        "' r='4' fill='" & _TargetCircleColour & 
		        "' stroke='" & _TargetStrokeColour & 
		        "' stroke-width='1.5'/>" &
		        
		        -- Actual circle with stroke
		        "<circle cx='" & _ActualNormalized & 
		        "' cy='" & _CenterY & 
		        "' r='4' fill='" & _Fill & 
		        "' stroke='" & _Stroke & 
		        "' stroke-width='1.5'/>"
		    
		    -- Wrap in PowerBI container with specific dimensions
		    VAR _Svg = 
		        SVG.Component.PowerBI(
		            _SvgContent,
		            _Actual,                -- sort_value
		            "0 0 " & _SvgWidth & " " & _SvgHeight,  -- viewbox
		            _SvgWidth,              -- width
		            _SvgHeight,             -- height
		            "#FFFFFF00"             -- transparent background
		        )
		    
		    RETURN
		        _Svg
		```
	lineageTag: 464a06ea-5e25-458f-a7c0-368566350c12

function 'SVG.Chart.Waterfall' = ```
		
		// Chart.WaterfallChartSimple
		// Creates a waterfall chart showing contribution to total with cumulative positioning (no labels)
		// Returns SVG string for Table/Matrix visuals (set Image size: Height 25px, Width 100px)
		(
		    // Actual value measure to display
		    // Example: [Sales Amount]
		    actual : EXPR,
		    
		    // Column for grouping/scope
		    // Example: 'Product'[Category]
		    column_one : ANYREF,
		    
		    // Bar fill colour for category items
		    // Example: "#dad9d8" (light grey)
		    colour_bar_category : SCALAR VAL,
		    
		    // Bar fill colour for totals
		    // Example: "#878582" (dark grey)
		    colour_bar_total : SCALAR VAL,
		    
		    // Connector colour
		    // Example: "#333333" (dark grey)
		    colour_connector : SCALAR VAL
		) =>
		    -- Chart dimensions
		    VAR _BarMax = 100
		    VAR _BarMin = 0
		    
		    -- Get current value
		    VAR _Actual = actual
		    
		    -- Determine bar colour based on context
		    VAR _BarFillColour = 
		        IF(
		            HASONEVALUE(column_one),
		            colour_bar_category,
		            colour_bar_total
		        )
		    
		    -- Calculate cumulative positioning
		    VAR _Scope = ALLSELECTED(column_one)
		    
		    VAR _Total = 
		        SUMX(_Scope, actual)
		    
		    -- Calculate cumulative sum of all items before current one
		    VAR _CumulativeBefore = 
		        SUMX(
		            FILTER(
		                _Scope,
		                actual > _Actual
		            ),
		            actual
		        )
		    
		    -- Calculate percentage positions
		    VAR _PercentageStart = 
		        IF(
		            HASONEVALUE(column_one),
		            DIVIDE(_CumulativeBefore, _Total),
		            0
		        )
		    
		    VAR _PercentageWidth = 
		        DIVIDE(_Actual, _Total)
		    
		    -- Calculate normalized positions
		    VAR _AxisRange = 
		        SVG.Calc.AxisRange(_BarMax, _BarMin)
		    
		    VAR _StartPos = 
		        _PercentageStart * _AxisRange
		    
		    VAR _BarWidth = 
		        _PercentageWidth * _AxisRange
		    
		    VAR _EndPos = 
		        MIN(_StartPos + _BarWidth, 99)
		    
		    -- Build SVG components (no labels)
		    VAR _SvgContent = 
		        
		        -- Main bar
		        SVG.Component.Rects(
		            _StartPos,              -- x
		            3,                      -- y
		            _BarWidth,              -- width
		            "75%",                  -- height
		            _BarFillColour,         -- fill
		            "",                     -- stroke
		            "",                     -- stroke_width
		            "",                     -- rx
		            ""                      -- opacity
		        ) &
		        
		        -- Start connector
		        SVG.Component.Rects(
		            _StartPos,              -- x
		            0,                      -- y
		            0.5,                    -- width
		            "100%",                 -- height
		            colour_connector,       -- fill
		            "",                     -- stroke
		            "",                     -- stroke_width
		            "",                     -- rx
		            ""                      -- opacity
		        ) &
		        
		        -- End connector
		        SVG.Component.Rects(
		            _EndPos,                -- x
		            0,                      -- y
		            0.5,                    -- width
		            "100%",                 -- height
		            colour_connector,       -- fill
		            "",                     -- stroke
		            "",                     -- stroke_width
		            "",                     -- rx
		            ""                      -- opacity
		        )
		    
		    -- Wrap in PowerBI container
		    VAR _Svg = 
		        SVG.Component.PowerBI(
		            _SvgContent,
		            _Actual,                -- sort_value
		            "",                     -- viewbox
		            "",                     -- width
		            "",                     -- height
		            "#FFFFFF00"             -- transparent background
		        )
		    
		    RETURN
		        _Svg
		```
	lineageTag: 1b7fa21b-38b8-4132-b285-43f7875ffdfe

function 'Comparison.Achievement' = ```
		
		// Compare to a target and return the relative percent
		// Example usage: Comparing sales to budget or forecast to get relative performance
		// Examples:
		// - 9/10  is 90%
		// - 11/10 is 110%
		(
		    // The actual value that you are measuring
		    actual : SCALAR NUMERIC VAL,
		    
		    // The target that you are comparing to
		    target : SCALAR NUMERIC VAL
		)
		
		=>
		    DIVIDE ( actual, target )
		```
	lineageTag: 7cf1811f-f5f4-4d4d-8649-d5ddafc7e989

function 'FormatString.Component.Symbols' = ```
		
		// Get comparison symbol based on style and value sign
		// Returns appropriate symbol for positive, negative, or zero values
		(
		    // Symbol style - number (1-9) or text:
		    // 1 or "ARROWS": ↑/↓
		    // 2 or "TRIANGLES": ▲/▼
		    // 3 or "PLUSMINUS": +/-
		    // 4 or "CHEVRONS": ˄/˅
		    // 5 or "GREENRED": 🟢/🔴
		    // 6 or "BLUEORANGE": 🔵/🟠
		    // 7 or "BLOCKARROWS": ⬆/⬇
		    // 8 or "CHECKCROSS": ✓/✗
		    // 9 or "NONE": no symbol
		    symbol_style: ANYVAL,
		    
		    // Value type: "POSITIVE", "NEGATIVE", or "ZERO"
		    value_type: STRING
		)
		=>
		    VAR _SymbolCode =
		        IF ( ISNUMBER ( symbol_style ),
		            symbol_style,
		            SWITCH ( UPPER ( symbol_style ),
		                "ARROWS", 1,
		                "TRIANGLES", 2,
		                "PLUSMINUS", 3,
		                "CHEVRONS", 4,
		                "GREENRED", 5,
		                "BLUEORANGE", 6,
		                "BLOCKARROWS", 7,
		                "CHECKCROSS", 8,
		                "NONE", 9,
		                9
		            )
		        )
		    
		    VAR _Symbol = 
		        SWITCH ( value_type,
		            "POSITIVE", 
		                SWITCH ( _SymbolCode,
		                    1, "↑",
		                    2, "▲",  
		                    3, "+",
		                    4, "˄",
		                    5, "🟢",
		                    6, "🔵",
		                    7, "⬆",
		                    8, "✓",
		                    9, "",
		                    ""
		                ),
		            "NEGATIVE",
		                SWITCH ( _SymbolCode,
		                    1, "↓",
		                    2, "▼",
		                    3, "-",
		                    4, "˅",
		                    5, "🔴",
		                    6, "🟠",
		                    7, "⬇",
		                    8, "✗",
		                    9, "",
		                    ""
		                ),
		            ""
		        )
		    
		    RETURN
		        _Symbol
		```
	lineageTag: 5adfd11c-e6b7-4598-b100-cc600147b93a

	annotation DAXLIB_PackageId = DaxLib.FormatString

	annotation DAXLIB_PackageVersion = 1.0.0-beta

function 'FormatString.Component.DecimalPlaces' = ```
		
		// Returns a 0 string repeated a number of times equal to the number of decimal places
		(
		    // Base format string
		    // Expects a valid format string base, i.e. "#,##0"
		    base_format: STRING,
		    
		    // Number of decimal places
		    // Expects an integer value from 0-9
		    decimal_places: INT64
		)
		=>
		    base_format
		    &
		    IF (
		        decimal_places > 0,
		        "."
		            & REPT ( "0", MIN ( decimal_places, 9 ) ),
		        ""
		    )
		```
