	partition Dates-dc28838f-eac0-4cba-8cd2-7f5b5a1b5d67 = calculated
		mode: import
		source = ```
				
				    var startDate = TODAY() - 31
				    var lastRefreshDate = DATEVALUE(MAX('Refresh Stats'[Last Refresh]))
