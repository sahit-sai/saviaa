      <rd:PowerBIDatasetName>REPLACE_WITH_DATASET_NAME</rd:PowerBIDatasetName>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsCategories">
      <Query>
        <DataSourceName>SemanticModel</DataSourceName>
        <CommandText>EVALUATE VALUES('Product'[Category]) ORDER BY 'Product'[Category]</CommandText>
      </Query>
      <Fields>
        <Field Name="Category">
          <DataField>Product[Category]</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Sales">
      <Query>
        <DataSourceName>SemanticModel</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="Category">
            <Value>=Parameters!Category.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>EVALUATE
SUMMARIZECOLUMNS (
  'Product'[Category],
  TREATAS ( { @Category }, 'Product'[Category] ),
  "Sales", [Sales Amount]
)
ORDER BY [Sales] DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="Category">
          <DataField>Product[Category]</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Sales">
          <DataField>[Sales]</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
