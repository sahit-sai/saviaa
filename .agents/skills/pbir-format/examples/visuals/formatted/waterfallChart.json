{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "waterfallChart_formatted_example",
  "position": {
    "x": 24,
    "y": 120,
    "z": 0,
    "height": 400,
    "width": 600,
    "tabOrder": 0
  },
  "visual": {
    "visualType": "waterfallChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Finance"
                    }
                  },
                  "Property": "Account"
                }
              },
              "queryRef": "Finance.Account",
              "nativeQueryRef": "Account",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Finance"
                    }
                  },
                  "Property": "Amount"
                }
              },
              "queryRef": "Finance.Amount",
              "nativeQueryRef": "Amount"
            }
          ]
        }
      }
    },
    "objects": {
      "sentimentColors": [
        {
          "properties": {
            "increaseFill": {
              "solid": {
                "color": {
                  "expr": {
                    "ThemeDataColor": {
                      "ColorId": 0,
                      "Percent": 0
                    }
                  }
                }
              }
            },
            "decreaseFill": {
              "solid": {
                "color": {
                  "expr": {
                    "ThemeDataColor": {
                      "ColorId": 3,
                      "Percent": 0
                    }
                  }
                }
              }
            },
            "totalFill": {
              "solid": {
                "color": {
                  "expr": {
                    "ThemeDataColor": {
                      "ColorId": 1,
                      "Percent": -0.25
                    }
                  }
                }
              }
            }
          }
        }
      ],
      "labels": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "labelDisplayUnits": {
              "expr": {
                "Literal": {
                  "Value": "1000000D"
                }
              }
            }
          }
        }
      ],
      "legend": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          }
        }
      ]
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Revenue Bridge'"
                }
              }
            }
          }
        }
      ],
      "subTitle": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'by Account Category'"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}
