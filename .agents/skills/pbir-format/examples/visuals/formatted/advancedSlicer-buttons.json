      "annotations": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Advanced slicer with button layout (1 row x 12 columns), rounded rectangles, conditional formatting on fill/accent bar/text colors using dataViewWildcard (matchingOption: 1), and label field showing OTD % (Value) measure.'"
                }
              }
            },
            "category": {
              "expr": {
                "Literal": {
                  "Value": "'Documentation'"
                }
              }
            }
          }
        },
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Extension Measure: OTD % (Value; PY REPT) = CALCULATE( [OTD % (Value)], DATEADD( Date[Date], -1, YEAR ) ) | Prior year comparison for on-time delivery percentage.'"
                }
              }
            },
            "category": {
              "expr": {
                "Literal": {
                  "Value": "'Report Extensions'"
                }
              }
            }
          }
        },
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Extension Measure: Cond. Color = IF ( MIN ( Date[Date] ) < [RefDate], IF ( [OTD % (Value)] > [OTD % (Value; PY REPT)], 1, 0 ) ) | Binary conditional color based on YoY performance comparison.'"
                }
              }
            },
            "category": {
              "expr": {
                "Literal": {
                  "Value": "'Report Extensions'"
                }
              }
            }
          }
        },
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Extension Measure: Cond. Color 2 = Returns #c2255c (dark red) if performance < -7.5% vs PY, otherwise #333333 (gray). Performance calculated as DIVIDE( _Actual - _Target, _Target ).'"
                }
              }
            },
            "category": {
              "expr": {
                "Literal": {
                  "Value": "'Report Extensions'"
                }
              }
            }
          }
        },
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Extension Measure: Cond. Color 3 = Multi-threshold color logic: #c2255c (dark red) < -7.5%, #e6c5da (light red) < -2.5%, #74B2FF (light blue) > 2.5%, #2D6390 (dark blue) > 7.5%, #ABABAB (gray) otherwise.'"
                }
              }
            },
            "category": {
              "expr": {
                "Literal": {
                  "Value": "'Report Extensions'"
                }
              }
            }
          }
        },
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Extension Measure: Title - \"OTD % (Value) for < Month >\" = Dynamic title showing selected month(s) using SELECTEDVALUE with CONCATENATEX fallback for multiple selections.'"
                }
              }
            },
            "category": {
              "expr": {
                "Literal": {
                  "Value": "'Report Extensions'"
                }
              }
            }
          }
        }
      ]
