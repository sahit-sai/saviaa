          ]
        },
        "TargetValue": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Targets"
                    }
                  },
                  "Property": "Revenue Target"
                }
              },
              "queryRef": "Targets.Revenue Target",
              "nativeQueryRef": "Revenue Target"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
